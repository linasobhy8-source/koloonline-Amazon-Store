<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Your Cart | Koloonline</title>

<link rel="stylesheet" href="style.css">

<style>
body{font-family:Arial;margin:0;background:#f5f5f5;}
header{background:#232f3e;color:#fff;padding:15px;text-align:center;font-size:22px;}
.navbar{display:flex;justify-content:space-between;padding:10px;background:#37475a;color:#fff;}
.products{padding:20px;display:grid;gap:15px;}
.card{background:#fff;padding:15px;border-radius:10px;box-shadow:0 4px 10px rgba(0,0,0,0.1);}
.buy-btn{background:#ff9900;border:none;padding:10px;width:100%;margin:5px 0;border-radius:6px;font-weight:bold;cursor:pointer;}
</style>

</head>

<body>

<header>🛒 Your Cart</header>

<div class="navbar">

<button onclick="location.href='index.html'">🏠 Home</button>
<button onclick="location.href='dashboard.html'">📊 Dashboard</button>

</div>

<div id="cart" class="products"></div>
<div id="summary" style="padding:20px;"></div>

<script>

/* ================= CART ================= */
let cart = JSON.parse(localStorage.getItem("cart") || "[]");

/* ================= TRACKING ================= */
async function trackEvent(eventType, data){

try{
await fetch("https://koloonline-store-git-main-linasobhys-projects.vercel.app/api/track",{
method:"POST",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({
event: eventType,
data: data,
page: "cart",
timestamp: new Date().toISOString(),
lang: navigator.language
})
});
}catch(e){
console.log("tracking failed");
}

}

/* ================= SAVE ================= */
function saveCart(){
localStorage.setItem("cart", JSON.stringify(cart));
renderCart();
updateCartCount();
}

/* ================= RENDER ================= */
function renderCart(){

let container = document.getElementById("cart");
let summary = document.getElementById("summary");

if(cart.length === 0){
container.innerHTML = "<div style='text-align:center;padding:50px'>🛒 Cart is empty</div>";
summary.innerHTML = "";
return;
}

let html = "";
let totalItems = 0;
let totalPrice = 0;

cart.forEach((item,index)=>{

if(!item.qty) item.qty = 1;
if(!item.price) item.price = 0;

totalItems += item.qty;
totalPrice += parseFloat(item.price) * item.qty;

html += `
<div class="card">

<img src="${item.image}" style="width:100%;height:180px;object-fit:contain">

<h3>${item.title}</h3>
<p>💲 ${item.price}</p>
<p>Qty: ${item.qty}</p>

<button class="buy-btn" onclick="increaseQty(${index})">➕</button>
<button class="buy-btn" onclick="decreaseQty(${index})">➖</button>
<button class="buy-btn" style="background:#d9534f" onclick="removeItem(${index})">❌ Remove</button>

</div>
`;
});

container.innerHTML = html;

summary.innerHTML = `
<div class="card">

<h3>🛒 Total Items: ${totalItems}</h3>
<h3>💰 Total Price: $${totalPrice.toFixed(2)}</h3>

<button class="buy-btn" onclick="checkout()">🚀 Checkout Now</button>
<button class="buy-btn" style="background:#d9534f" onclick="clearCart()">🗑 Clear Cart</button>

</div>
`;

}

/* ================= ACTIONS ================= */
function removeItem(index){

trackEvent("remove_item", cart[index]);

cart.splice(index,1);
saveCart();

}

function increaseQty(index){

cart[index].qty = (cart[index].qty || 1) + 1;

trackEvent("qty_increase", cart[index]);

saveCart();

}

function decreaseQty(index){

if(cart[index].qty > 1){
cart[index].qty -= 1;
trackEvent("qty_decrease", cart[index]);
}else{
trackEvent("remove_item", cart[index]);
cart.splice(index,1);
}

saveCart();

}

function clearCart(){

if(confirm("Clear all items?")){
trackEvent("clear_cart", "all");
cart = [];
saveCart();
}

}

/* ================= SAVE ORDER ================= */
function saveOrder(){

let orders = JSON.parse(localStorage.getItem("orders") || "[]");

let order = {
id: Date.now(),
date: new Date().toISOString(),
items: cart,
totalItems: cart.reduce((s,i)=>s+(i.qty||1),0),
totalPrice: cart.reduce((s,i)=>s+(parseFloat(i.price||0)*(i.qty||1)),0)
};

orders.push(order);

localStorage.setItem("orders", JSON.stringify(orders));

trackEvent("order_created", order);

}

/* ================= CHECKOUT ================= */
function checkout(){

if(cart.length === 0){
alert("Cart is empty 🛒");
return;
}

trackEvent("checkout_start", {
items: cart.length
});

saveOrder();

cart = [];
saveCart();

alert("🎉 Order placed successfully!");

window.location.href = "thankyou.html";

}

/* ================= COUNT ================= */
function updateCartCount(){
let count = cart.reduce((s,i)=>s+(i.qty||1),0);
localStorage.setItem("cartCount", count);
}

/* ================= INIT ================= */
renderCart();
updateCartCount();

</script>

</body>
</html>
