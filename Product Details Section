const params = new URLSearchParams(window.location.search);
const asin = params.get("asin");

/* ================= PRODUCTS ================= */
let products = [
{
asin:"B09V7Z4TJG",
title:"Smart Watch Pro",
price:49.99,
image:"https://m.media-amazon.com/images/I/61IMRs+o0iL._AC_SL1500_.jpg"
