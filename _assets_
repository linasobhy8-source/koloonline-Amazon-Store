<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Koloonline Store</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 0; }
    .navbar { display: flex; background: #333; padding: 10px; }
    .navbar button { color: #fff; background: #444; border: none; margin-right: 10px; padding: 10px; cursor: pointer; }
    .container { display: flex; flex-wrap: wrap; padding: 20px; gap: 20px; }
    .card { background: #fff; padding: 20px; border-radius: 10px; width: 300px; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .card h2 { margin-top: 0; }
    footer { text-align: center; padding: 20px; background: #333; color: #fff; margin-top: 20px; }
  </style>
</head>
<body>

<header>
  <h1>Koloonline Store</h1>
</header>

<div class="navbar">
  <button onclick="location.href='index.html'">🏠 Home</button>
  <button onclick="location.href='blog.html'">📰 Blog</button>
  <button onclick="location.href='dashboard.html'">📊 Dashboard</button>
</div>

<div class="container">
  <div class="card" onclick="trackProduct('B09V7Z4TJG')">
    <h2>🔥 Smart Watch Pro</h2>
    <p>Top smart watches with fitness tracking, health features and battery life.</p>
    <button onclick="openProduct(event,'product.html','B09V7Z4TJG')">📖 View Product</button>
  </div>
  <div class="card" onclick="trackProduct('B08G9P7N2X')">
    <h2>📱 Wireless Earbuds</h2>
    <p>High quality sound, low price, best Amazon picks.</p>
    <button onclick="openProduct(event,'product.html','B08G9P7N2X')">📖 View Product</button>
  </div>
</div>

<footer>
  <p>© 2026 Koloonline Store by Lina Sobhy</p>
</footer>

<script>
  // تتبع الأحداث بدون كشف أي أسرار
  function trackEvent(type, category){
    fetch("/api/track", { // استخدم مسار نسبي للـ API بدون وضع أي مفاتيح مباشرة
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        event: type,
        category: category,
        page: "index",
        timestamp: new Date().toISOString(),
        lang: navigator.language
      })
    }).catch(e => console.log("tracking error"));
  }

  function trackProduct(asin) {
    trackEvent("product_click", asin);
  }

  function openProduct(e, url, asin) {
    e.stopPropagation();
    trackEvent("product_open", asin);
    window.location.href = url;
  }
</script>

</body>
</html>
