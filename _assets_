function trackEvent(type, category){
  fetch("/api/track", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({
        event: type,
        category: category,
        page: "index",
        timestamp: new Date().toISOString(),
        lang: navigator.language
    })
  }).catch(e => console.log("tracking error"));
}

function trackProduct(asin){
    trackEvent("product_click", asin);
}

function openProduct(e, url, asin){
    e.stopPropagation();
    trackEvent("product_open", asin);
    window.location.href = url;
}
