<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Koloonline Store</title>
<meta name="description" content="Koloonline Amazon Store - اكتشف أفضل منتجات Amazon مع عروض حصرية وأسعار مميزة.">
<link rel="icon" href="/favicon.ico">

<style>
body{font-family:Arial,margin:0;background:#f5f5f5;}
a{text-decoration:none;color:#fff;}
.header-main{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;padding:15px 30px;background:#232f3e;color:#fff;}
.logo{height:50px;max-width:150px;}
.navbar{list-style:none;padding:0;margin:0;display:flex;gap:20px;flex-wrap:wrap;}
.navbar li{display:inline;}
.navbar a{color:#fff;font-weight:500;}
.navbar a:hover{color:#FF9900;}
.search-bar{display:flex;gap:10px;flex-wrap:wrap;}
.search-input{padding:10px;border:1px solid #ccc;border-radius:25px;width:200px;}
.products{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:15px;margin:20px 0;}
.card{background:#fff;padding:15px;border-radius:10px;box-shadow:0 3px 10px rgba(0,0,0,0.1);text-align:center;}
.card img{width:100%;height:180px;object-fit:contain;}
.price{color:#b12704;font-weight:bold;}
.buy-btn{background:#ff9900;border:none;padding:10px;width:100%;margin-top:10px;font-weight:bold;cursor:pointer;border-radius:6px;}
.buy-btn.whatsapp{background:#25D366;color:#fff;}
.box{max-width:1000px;margin:30px auto;background:#fff;padding:20px;border-radius:12px;}
</style>
</head>

<body>

<!-- HEADER -->
<div class="header-main">
  <img src="/assets/1000276862.png" alt="Koloonline Logo" class="logo">

  <ul class="navbar">
    <li><a href="/">🏠 Home</a></li>
    <li><a href="/products">🛒 Products</a></li>
    <li><a href="/blog">📚 Blog</a></li>
    <li><a href="/faq">❓ FAQ</a></li>
    <li><a href="/contact">✉ Contact</a></li>
    <li>Cart: <span id="cart-count">0</span></li>
  </ul>

  <div class="search-bar">
    <input type="text" id="search" class="search-input" placeholder="Search products...">
    <button onclick="searchProducts()">🔍</button>
  </div>
</div>

<!-- CONTENT -->
<div class="box">
<h1>Welcome to Koloonline Store</h1>
<p>Explore trending products 👇</p>

<div id="productsContainer" class="products"></div>
</div>

<script>
// CART
let cart = JSON.parse(localStorage.getItem("cart") || "[]");
function updateCartCount(){
  document.getElementById("cart-count").textContent = cart.length;
}
updateCartCount();

// PRODUCTS
const products = [
  {id:"1", title:"Echo Dot 5", price:49.99, asin:"B09B8Q3YHJ", image:"/assets/product1.jpg"},
  {id:"2", title:"Smart Watch Pro", price:79.99, asin:"B09V7Z4TJG", image:"/assets/product2.jpg"},
  {id:"3", title:"Fire TV Stick 4K", price:39.99, asin:"B08XJG8MQM", image:"/assets/product3.jpg"}
];

// AFFILIATE LINK
function getAffiliateLink(asin){
  return `https://www.amazon.com/dp/${asin}?tag=koloonlinesto-20`;
}

// RENDER
function renderProducts(list = products){
  const container = document.getElementById("productsContainer");
  container.innerHTML = "";

  list.forEach(p=>{
    const card = document.createElement("div");
    card.className = "card";

    card.innerHTML = `
      <img src="${p.image}" alt="${p.title}">
      <h4>${p.title}</h4>
      <p class="price">$${p.price}</p>
      <button class="buy-btn" onclick="buyProduct('${p.asin}')">🔥 Buy</button>
      <button class="buy-btn whatsapp" onclick="orderWhatsApp('${p.title}')">📲 WhatsApp</button>
    `;

    container.appendChild(card);
  });
}

// BUY
function buyProduct(asin){
  window.open(getAffiliateLink(asin), "_blank");
}

// WHATSAPP
function orderWhatsApp(title){
  window.open(`https://wa.me/201205271929?text=${encodeURIComponent("I want: "+title)}`);
}

// SEARCH
function searchProducts(){
  const q = document.getElementById("search").value.toLowerCase();
  const filtered = products.filter(p => p.title.toLowerCase().includes(q));
  renderProducts(filtered);
}

// INIT
renderProducts();
</script>

</body>
</html>
