{
  "version": 2,
  "builds": [
    { "src": "app.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/cart", "dest": "/cart.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/api/(.*)", "dest": "/app.js" }
  ]
}
