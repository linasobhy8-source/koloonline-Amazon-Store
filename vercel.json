{
  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },

    { "source": "/", "destination": "/index.html" },

    { "source": "/product", "destination": "/product.html" },
    { "source": "/product.html", "destination": "/product.html" },

    { "source": "/products", "destination": "/products.html" },

    { "source": "/cart", "destination": "/cart.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },

    { "source": "/about", "destination": "/about.html" },
    { "source": "/privacy", "destination": "/privacy.html" },

    { "source": "/p/(.*)", "destination": "/product.html?asin=$1" },
    { "source": "/dp/(.*)", "destination": "/product.html?asin=$1" }
  ],

  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },

    {
      "source": "/product.html",
      "destination": "/product",
      "permanent": false
    }
  ]
}
