{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node@3.0.0",
      "config": {
        "runtime": "nodejs20.x"
      }
    },
    {
      "src": "_assets_/css/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
